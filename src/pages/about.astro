---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import Features from "@/components/widgets/Features.astro";
import Values from "@/components/widgets/Values.astro";
import Button from "@/components/ui/Button.astro";
import Card from "@/components/ui/Card.astro";

const metadata = {
  title: "About",
  description:
    "Agentic Pacific delivers sovereign AI systems for legal research, FinTech oversight, document intelligence, earth observations, and custom agents.",
};

const capabilityAreas = [
  {
    title: "Legal AI systems",
    description:
      "Private legal research and drafting assistants grounded in Fiji legislation, bills, and jurisprudence.",
    icon: "lucide:scale",
  },
  {
    title: "FinTech oversight",
    description:
      "Search, synthesis, and compliance intelligence across file shares, CRMs, onboarding records, and reports.",
    icon: "lucide:landmark",
  },
  {
    title: "Document AI",
    description:
      "OCR, parsing, metadata extraction, and document-driven workflow automation for enterprise operations.",
    icon: "lucide:file-search",
  },
  {
    title: "Earth observation AI",
    description:
      "Embeddings, spatial machine learning, and geospatial pipelines for environmental and infrastructure insight.",
    icon: "lucide:satellite",
  },
  {
    title: "Custom agent systems",
    description:
      "Orchestrated agents that plan, act through tools and APIs, and report with guardrails and observability.",
    icon: "lucide:bot",
  },
  {
    title: "Cloud-native delivery",
    description:
      "Production deployment across storage, vector search, APIs, monitoring, and secure internal interfaces.",
    icon: "lucide:cloud-cog",
  },
];

const interfaceShowcase = [
  {
    title: "Fiji Legal AI Workspace",
    filename: "ios-legal-1",
    image: "/ios/ios-legal-1.png",
    alt: "Legal AI mobile workspace showing platform status and retrieval metrics",
    description:
      "A mobile-capable legal operations dashboard with indexed corpus coverage, confidence metrics, and API health indicators.",
  },
  {
    title: "Grounded Legal Query Flow",
    filename: "ios-legal-2",
    image: "/ios/ios-legal-2.png",
    alt: "Legal AI query composer and grounded response screen",
    description:
      "A query interface that surfaces grounded answers, chunk retrieval counts, and workflow guidance for citation-backed legal research.",
  },
  {
    title: "SPX Market Overview",
    filename: "ios-spx-1",
    image: "/ios/ios-spx-1.png",
    alt: "South Pacific Stock Exchange dashboard overview on mobile",
    description:
      "A live real-time South Pacific Stock Exchange snapshot focused on pricing, liquidity, valuation, and source-linked market data refreshes.",
  },
  {
    title: "SPX Interactive Stock Chart",
    filename: "ios-spx-2",
    image: "/ios/ios-spx-2.png",
    alt: "Interactive SPX market chart with ranking controls",
    description:
      "A ranked chart experience for exploring listed counters by market cap, price, or volume inside a compact mobile UI.",
  },
  {
    title: "SPX Quick Scan",
    filename: "ios-spx-3",
    image: "/ios/ios-spx-3.png",
    alt: "SPX quick scan screen listing largest and most active companies",
    description:
      "A rapid scan panel highlighting the largest companies and most actively traded names from the latest local market refresh.",
  },
  {
    title: "SPX Single Company Spotlight",
    filename: "ios-spx-4",
    image: "/ios/ios-spx-4.png",
    alt: "Focused SPX stock spotlight screen for a selected company",
    description:
      "A focused company detail view with price, market cap, ratio, yield, and bid-ask context for fast security-level review.",
  },
  {
    title: "Fijian-English Translation App",
    filename: "ios-fijian-1",
    image: "/ios/ios-fijian-1.png",
    alt: "Fijian and English translation app home screen",
    description:
      "A bilingual translation experience for everyday communication, with guided actions for instant Fiji-English language conversion.",
  },
  {
    title: "Fijian-English Translation Result",
    filename: "ios-fijian-2",
    image: "/ios/ios-fijian-2.png",
    alt: "Fijian text input and English translation output on mobile",
    description:
      "A side-by-side translation workflow showing source text, translated output, and example-driven interaction for fast verification.",
  },
];
---

<BaseLayout {metadata}>
  <Content
    tagline="About"
    title="AI systems for Pacific knowledge work"
    description={[
      "<b class='text-justify'>Agentic Pacific</b> is a consultancy service based in Suva, Fiji Islands, and is operated by professionals with deep technical expertise and 25 years of experience in the scientific, technical and development sector within the Pacific region.",
      "<br/><br/><hr/><br/><span class='text-justify'>Agentic Pacific designs and deploys AI products for organizations that need more than a generic <i>\"off-the-shelf\"</i> solutions. Our work centers on sovereign architectures, retrieval-backed reasoning, and domain-specific context engineering.</span>",
      "<span class='text-justify'>Across legal, financial, document-heavy, and geospatial environments, we turn fragmented data into systems that can retrieve evidence, explain outputs, and support complete <i>end-to-end</i> operational workflows.</span>",
    ]}
    image="/illustrations/about.svg"
    imageAlt="About Agentic Pacific illustration"
  />

  <Features
    tagline="Products"
    title="What we build"
    subtitle="Our product direction focuses on high-trust AI systems that need to operate with clear evidence, private infrastructure, and measurable business impact."
    features={[
      {
        title: "Private RAG platforms",
        description:
          "Knowledge systems that combine LLMs with curated domain corpora, citation links, and controlled enterprise access.",
        icon: "lucide:database-zap",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Workflow copilots",
        description:
          "Interfaces that draft, summarize, compare, and escalate work across legal, compliance, and operations teams.",
        icon: "lucide:workflow",
        iconClass: "bg-emerald-500/10 text-emerald-400",
      },
      {
        title: "Spatial intelligence pipelines",
        description:
          "Geospatial AI workflows that transform Earth observation data into searchable, decision-ready insight.",
        icon: "lucide:map",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
    ]}
  />

  <section class="reveal relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-6xl px-4 py-8 md:px-6 md:py-12">
      <div class="max-w-3xl">
        <div class="text-sm font-semibold uppercase tracking-[0.2em] text-primary">
          Product Showcase
        </div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">
          iOS Native Apps for Agentic Pacific's AI Systems, Services and Tools
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
         App User Interfaces across several <b>Agentic Pacific</b> prototypes, presented as <b>reusable product patterns</b> across legal AI, financial market intelligence, earth observations and bilingual models and tools.
        </p>
      </div>

      <div class="mt-10 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
        {
          interfaceShowcase.map((screen) => (
            <Card class="group h-full overflow-hidden p-0 hover:-translate-y-1 hover:shadow-md">
              <div class="border-b border-border bg-muted/30 p-4">
                <div class="mx-auto max-w-[260px] rounded-[1.5rem] border border-border/70 bg-background/80 p-2 shadow-sm">
                  <img
                    src={screen.image}
                    alt={screen.alt}
                    loading="lazy"
                    class="h-auto w-full rounded-[1.1rem] object-cover"
                  />
                </div>
              </div>

              <div class="p-6">
                <div class="text-xs font-semibold uppercase tracking-[0.2em] text-primary/80">
                  {screen.filename}
                </div>
                <h3 class="mt-3 text-2xl font-bold text-foreground">
                  {screen.title}
                </h3>
                <p class="mt-3 leading-relaxed text-muted-foreground">
                  {screen.description}
                </p>
              </div>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <Values
    items={capabilityAreas}
    columns={3}
    tagline="Capabilities"
    title="Services and delivery capability"
    subtitle="Agentic Pacific combines consulting, product engineering, and deployment support across the full AI system lifecycle."
  />

  <section class="reveal relative not-prose scroll-mt-[72px]">
    <div class="relative mx-auto max-w-4xl px-4 py-8 md:px-6 md:py-12">
      <div
        class="rounded-3xl border border-border bg-card p-8 shadow-sm md:p-10"
      >
        <div
          class="text-sm font-semibold uppercase tracking-[0.2em] text-primary"
        >
          Contact
        </div>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">
          Talk to Agentic Pacific
        </h2>
        <p class="mt-4 text-lg text-muted-foreground">
          If you are exploring a sovereign legal assistant, enterprise document
          intelligence, a FinTech oversight engine, or a custom agent platform,
          get in touch and we can shape the right architecture for your
          environment.
        </p>
        <div
          class="mt-6 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
        >
          <div>
            <div class="text-sm font-medium text-muted-foreground">Email</div>
            <a
              href="#"
              class="mt-1 inline-block text-xl font-semibold text-primary hover:underline"
            >
              info@agenticpacific.com.fj
            </a>
          </div>
          <Button type="button" data-contact-open variant="primary" size="lg">
            Start a conversation
          </Button>
        </div>
      </div>

      <div class="text-center">
        <br/>
        ROC Business Name and Registration Number
        <br />
        <b>Agentic Pacific Consultancy | 2026RB008817</b>
      </div>
    </div>
  </section>
</BaseLayout>
