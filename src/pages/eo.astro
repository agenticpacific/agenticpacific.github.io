---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import Features from "@/components/widgets/Features.astro";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import ReferenceLinks from "@/components/sections/ReferenceLinks.astro";

const metadata = {
  title: "Earth Observations",
  description:
    "Earth observation intelligence using embeddings, spatial machine learning, and geospatial workflows.",
};

const governanceItems = [
  {
    title: "Searchable Earth data",
    description:
      "Embeddings create dense numerical summaries that make decades of imagery easier to search for crops, floods, fires, biodiversity, roads, and more.",
    icon: "lucide:search-code",
  },
  {
    title: "Lower compute barriers",
    description:
      "The World Economic Forum article describes Earth embeddings as semantic compressions that can be less than 5% of the original image size.",
    icon: "lucide:gauge",
  },
  {
    title: "Decision support",
    description:
      "These models can help flood detection, crop prediction, infrastructure analysis, and climate planning by surfacing patterns humans cannot review at scale.",
    icon: "lucide:radar",
  },
  {
    title: "Governance still matters",
    description:
      "Accessibility, privacy, security, bias, and misuse prevention remain essential when operationalizing geospatial AI systems.",
    icon: "lucide:shield-alert",
  },
];

const references = [
  {
    label: "World Economic Forum - AI embeddings for Earth observation",
    href: "https://www.weforum.org/stories/2024/10/ai-embeddings-earth-observation/",
    note: "Source material on embeddings, semantic compression, geospatial search, climate value, and governance considerations.",
  },
];
---

<BaseLayout {metadata}>
  <Content
    tagline="Earth Observations"
    title="From pixels to predictions"
    description={[
      "Earth observation data is abundant, but usable insight is still difficult to extract at scale. Agentic Pacific applies embeddings and spatial machine learning so geospatial archives become easier to search, compare, and operationalize.",
      "The result is a more searchable picture of ecosystems, biodiversity, floods, crops, infrastructure, and land change - especially valuable for Pacific planning and climate resilience workflows.",
    ]}
    image="/illustrations/eo.svg"
    imageAlt="Earth observations illustration"
  />

  <Features
    tagline="Why embeddings matter"
    title="A new layer of geospatial understanding"
    subtitle="The World Economic Forum describes Earth embeddings as a way to translate raw data into compact, meaningful summaries that preserve context and pattern."
    features={[
      {
        title: "Dense summaries",
        description:
          "Embeddings compress huge imagery archives into vectors that can capture meaning across space, time, and land-use concepts.",
        icon: "lucide:binary",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Faster search and classification",
        description:
          "Open model benchmarks cited in the article show over 90% accuracy on tasks such as land-use classification, aquaculture detection, and biomass estimation.",
        icon: "lucide:scan-search",
        iconClass: "bg-emerald-500/10 text-emerald-400",
      },
      {
        title: "Climate and economic value",
        description:
          "The same WEF ecosystem points to major potential value from Earth observation when more stakeholders can actually use it.",
        icon: "lucide:leaf",
        iconClass: "bg-cyan-500/10 text-cyan-400",
      },
    ]}
  />

  <Content2
    tagline="Operational opportunity"
    title="Search the planet with local questions"
    description={[
      "Instead of manually reviewing pixels and maps, teams can work with embedding-backed systems that understand both individual features and broader environmental patterns.",
    ]}
    image="/illustrations/eo.svg"
    imageAlt="Embeddings for earth observation illustration"
    items={[
      {
        title: "Natural resource monitoring",
        description:
          "Track forest change, river flows, coastal activity, biodiversity patterns, or land-use transitions using semantic similarity rather than manual tagging alone.",
      },
      {
        title: "Disaster and resilience workflows",
        description:
          "Support flood response, drought monitoring, or infrastructure planning with faster access to relevant historical and current imagery context.",
      },
      {
        title: "Open-data leverage",
        description:
          "Earth observation is unusually rich in openly licensed, real-world data, making it an attractive foundation for transparent AI systems.",
      },
      {
        title: "Governed deployment",
        description:
          "Operational systems still need controls for privacy, national security, bias, and responsible use before they move beyond prototype status.",
      },
    ]}
  />

  <Values
    items={governanceItems}
    columns={2}
    tagline="What Agentic Pacific brings"
    title="Spatial AI with context and governance"
    subtitle="We combine geospatial pipelines with retrieval, application design, and deployment thinking so Earth data becomes decision-ready rather than merely available."
  />

  <ReferenceLinks
    links={references}
    subtitle="This page summarizes the World Economic Forum's discussion of AI embeddings and their implications for Earth observation."
  />
</BaseLayout>
