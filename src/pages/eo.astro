---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import Features from "@/components/widgets/Features.astro";
import Content2 from "@/components/widgets/Content2.astro";
import Values from "@/components/widgets/Values.astro";
import ComparisonTable from "@/components/sections/ComparisonTable.astro";
import ReferenceLinks from "@/components/sections/ReferenceLinks.astro";

const metadata = {
  title: "Earth Observations & Earth Intelligence for the Pacific",
  description:
    "AI-powered Earth observation intelligence for Pacific Island nations — climate resilience, land cover monitoring, coastal protection, and natural resource management using embeddings and spatial machine learning.",
};

const pacificApplications = [
  {
    title: "Climate resilience & early warning",
    description:
      "AI-powered analysis of satellite imagery and local sensor data delivers early warning systems for cyclones, floods, and storm surges — providing Pacific communities with critical time to prepare and protect lives and infrastructure.",
    icon: "lucide:cloud-lightning",
  },
  {
    title: "Land cover & land-use change",
    description:
      "Monitor deforestation, agricultural expansion, urban growth, and land degradation across island landscapes. AI models trained on historical archives detect changes that manual review cannot match at scale.",
    icon: "lucide:trees",
  },
  {
    title: "Coastal & marine monitoring",
    description:
      "Track coral reef health, mangrove extent, coastal erosion, and sea-level impacts using satellite-derived bathymetry, seagrass mapping, and marine habitat classification — all critical for Pacific Island livelihoods.",
    icon: "lucide:waves",
  },
  {
    title: "Biodiversity & carbon management",
    description:
      "High-resolution monitoring of ecosystems, habitat classification, and carbon storage analysis support conservation, restoration, and compliance with the Kunming-Montreal Biodiversity Framework and the Paris Agreement.",
    icon: "lucide:leaf",
  },
];

const governanceItems = [
  {
    title: "Searchable Earth data",
    description:
      "Embeddings create dense numerical summaries that make decades of imagery searchable for crops, floods, fires, biodiversity, coral reefs, and more — turning petabytes of raw pixels into actionable Pacific intelligence.",
    icon: "lucide:search-code",
  },
  {
    title: "Lower compute barriers",
    description:
      "Earth embeddings are semantic compressions often less than 5% of the original image size, reducing the compute and bandwidth demands that disproportionately affect remote Pacific communities.",
    icon: "lucide:gauge",
  },
  {
    title: "Decision-ready intelligence",
    description:
      "GEO's Post-2025 Strategy emphasises Earth Intelligence — not just data access, but verified, actionable insights co-produced with local and Indigenous communities to drive tangible change.",
    icon: "lucide:radar",
  },
  {
    title: "Governance & data sovereignty",
    description:
      "Accessibility, privacy, bias prevention, and data sovereignty remain essential when operationalizing geospatial AI — especially in Pacific contexts where cultural and environmental sensitivity is paramount.",
    icon: "lucide:shield-alert",
  },
];

const comparisonHeaders = [
  "Capability",
  "Traditional Approach",
  "With Agentic Pacific AI",
];

const comparisonRows = [
  {
    label: "Land cover analysis",
    values: [
      "Manual classification of satellite imagery across fragmented tools.",
      "AI-driven land-use classification with over 90% accuracy using foundation models like OlmoEarth and IBM TerraMind earth foundation models.",
    ],
  },
  {
    label: "Climate monitoring",
    values: [
      "Reliance on global models with limited Pacific-specific resolution.",
      "Localised embeddings integrating satellite, sensor, and community knowledge for island-scale insight.",
    ],
  },
  {
    label: "Disaster response",
    values: [
      "Reactive post-event assessment using manual image review.",
      "Near real-time flood detection, cyclone tracking, and damage assessment with AI-powered early warning.",
    ],
  },
  {
    label: "Data accessibility",
    values: [
      "Requires GIS expertise and high-bandwidth connectivity.",
      "Natural language queries over compressed embeddings — accessible even with limited connectivity.",
    ],
  },
  {
    label: "Resource monitoring",
    values: [
      "Periodic field surveys with limited geographic coverage.",
      "Continuous satellite-based monitoring of forests, reefs, mangroves, and water resources at scale.",
    ],
  },
];

const references = [
  {
    label: "What is Earth Intelligence? — Group on Earth Observations",
    href: "https://earthobservations.org/resources/what-is-earth-intelligence",
    note: "Earth Intelligence transforms raw data into actionable insights by integrating Earth and social science, advanced analytics, AI, and co-produced knowledge from local and Indigenous communities.",
  },
  {
    label: "GEO Post-2025 Strategy",
    href: "https://earthobservations.org/storage/documents/Key-Documents/GEO%20Post%202025%20Strategy%20Full%20Document.pdf",
    note: "GEO's strategic vision commits to ensuring that Earth observation data serves as a driver of tangible change — bridging knowledge gaps and fostering innovation for sustainable development.",
  },
  {
    label: "How AI is revolutionizing Earth observation — World Economic Forum",
    href: "https://www.weforum.org/stories/2024/10/ai-embeddings-earth-observation/",
    note: "AI embeddings translate raw satellite data into meaningful insights, enabling over 90% accuracy in land-use classification, aquaculture detection, and biomass estimation.",
  },
  {
    label: "How Is AI Empowering Earth Intelligence? — InformationWeek",
    href: "https://www.informationweek.com/machine-learning-ai/how-is-ai-empowering-earth-intelligence-",
    note: "Advanced AI tools deliver actionable insights for deforestation tracking, precision agriculture, water management, biodiversity conservation, and climate prediction.",
  },
];
---

<BaseLayout {metadata}>
  <Content
    tagline="Earth Intelligence for the Pacific"
    title="From Pixels to Predictions: AI-Powered Earth Observation for Pacific Island Nations"
    description={[
      "Pacific Island nations face some of the most urgent climate and environmental challenges on Earth — rising sea levels, intensifying cyclones, coral reef degradation, and threats to biodiversity and food security. Yet the satellite data needed to respond exists in overwhelming volumes that are difficult to access and interpret.",
      "Agentic Pacific bridges this gap by applying AI embeddings, spatial machine learning, and the Earth Intelligence framework championed by GEO's Post-2025 Strategy — transforming raw Earth observation data into decision-ready insights for climate resilience, land cover monitoring, coastal protection, and natural resource management across the Pacific.",
    ]}
    image="/illustrations/eo.svg"
    imageAlt="Earth Intelligence for the Pacific"
  />

  <Features
    tagline="Pacific applications"
    title="AI-powered intelligence for Pacific priorities"
    subtitle="From climate adaptation to biodiversity conservation, Agentic Pacific delivers Earth Intelligence tailored to the unique challenges of Small Island Developing States. Drawing on platforms like Open Data Cube (ODC) and GEO's Global Observation Network, we make decades of satellite data actionable."
    features={pacificApplications}
  />

  <Content2
    tagline="The technology"
    title="Earth embeddings: a new way of seeing"
    description={[
      "The World Economic Forum describes Earth embeddings as a paradigm shift — AI creates dense mathematical summaries from satellite imagery that are often less than 5% of the original size, yet capture meaning across space, time, and environmental concepts. Foundation models like Clay have demonstrated over 90% accuracy in classifying land use, detecting aquaculture, and estimating biomass.",
      "For the Pacific, this means teams can ask natural-language questions about their environment — 'Where has mangrove cover declined in the last five years?' or 'Which coastal areas face the highest erosion risk?' — and receive verified, cited answers in seconds rather than weeks of manual analysis.",
    ]}
    image="/illustrations/eo.svg"
    imageAlt="Earth embeddings and AI illustration"
    items={[
      {
        title: "Land cover & deforestation tracking",
        description:
          "AI analyses satellite archives to detect changes in forest cover, agricultural land, and urban expansion in real-time — helping Pacific governments meet their commitments under the Paris Agreement and the Kunming-Montreal Biodiversity Framework.",
      },
      {
        title: "Coastal resilience & marine resources",
        description:
          "Satellite-derived products including seagrass mapping, marine habitat classification, and bathymetry support fisheries management, coral reef conservation, and coastal infrastructure planning.",
      },
      {
        title: "Water & natural resource management",
        description:
          "Monitor river flows, water quality, drought conditions, and watershed health using AI-driven synthesis of satellite, sensor, and community-sourced data — critical for Pacific food and water security.",
      },
      {
        title: "Disaster risk reduction & early warning",
        description:
          "Integrate satellite data with local hydrological models to deliver early warning systems for floods, cyclones, and storm surges — aligned with the Sendai Framework and GEO's Early Warnings for All initiative.",
      },
    ]}
  />

  <Values
    items={governanceItems}
    columns={2}
    tagline="What Agentic Pacific brings"
    title="Spatial AI with Pacific context and governance"
    subtitle="We combine geospatial pipelines with AI retrieval, local context engineering, and deployment thinking — ensuring Earth data becomes decision-ready intelligence that respects data sovereignty, cultural sensitivity, and the specific needs of Pacific communities."
  />

  <ComparisonTable
    tagline="Impact comparison"
    title="Traditional approaches vs. AI-powered Earth Intelligence"
    subtitle="How Agentic Pacific transforms Earth observation workflows for Pacific stakeholders."
    headers={comparisonHeaders}
    rows={comparisonRows}
  />

  <ReferenceLinks
    links={references}
    subtitle="This page draws on the GEO Post-2025 Strategy the World Economic Forum's analysis of AI embeddings to present Agentic Pacific's approach to Earth Intelligence for the Pacific."
  />
</BaseLayout>
