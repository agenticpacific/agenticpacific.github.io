---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Content from "@/components/widgets/Content.astro";
import Hero from "@/components/widgets/Hero.astro";

const metadata = {
  title: "Public-Facing Demonstrations",
  description:
    "Agentic Pacific's Vertical Slice Demos showcase our AI capabilities in action across various domains.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <div align="center" class="py-16" style="margin-top: -70px;">
    <img
      id="site-logo"
      src="/agentic-pacific-icon-name-light.svg"
      alt="Agentic Pacific Logo"
      class="mb-8 w-64"
    />
    <h1
      style="margin-top: -40px;"
      class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent text-[4rem] font-extrabold tracking-tighter mb-4"
    >
      Public-Facing Demonstrations
    </h1>
    <h3 style="margin-top: -20px; text-decoration: underline;">
      Agentic Pacific's Vertical Slice Demos - Showcasing our AI capabilities in
      action across various domains.
    </h3>
    <br />

    <h2 class="font-extrabold text-2xl">
      Fijian-English Real-Time Translation Agent Using Custom-Built Large
      Language Model
    </h2>
    <h3>
      The <b>1st Ever</b> Fijian Language-Enabled Large Language Model (LLM)
    </h3>

    <div
      class="mx-auto mt-10 w-full max-w-5xl rounded-2xl border border-border bg-card shadow-xl overflow-hidden"
    >
      <!-- Card header -->
      <div class="flex items-center gap-3 border-b border-border px-6 py-4">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-full bg-primary/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 text-primary"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m5 8 6 6"></path><path d="m4 14 6-6 2-3"></path><path
              d="M2 5h12"></path><path d="M7 2h1"></path><path
              d="m22 22-5-10-5 10"></path><path d="M14 18h6"></path>
          </svg>
        </span>
        <div class="text-left">
          <p class="text-sm font-semibold text-foreground">Live Translation</p>
          <p class="text-xs text-muted-foreground">
            Powered by Agentic Pacific's Fijian LLM
          </p>
        </div>
        <span
          id="status-badge"
          class="ml-auto hidden items-center gap-1.5 rounded-full bg-green-500/10 px-3 py-1 text-xs font-medium text-green-500"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
          Online
        </span>
      </div>

      <!-- Translation grid -->
      <div class="grid grid-cols-1 gap-0 sm:grid-cols-2">
        <!-- Input -->
        <div
          class="flex flex-col border-b border-border p-7 sm:border-b-0 sm:border-r"
        >
          <label
            for="fijian-input"
            class="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-3.5 w-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path
                d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"></path><path
                d="M2 12h20"></path></svg
            >
            Fijian
          </label>
          <textarea
            id="fijian-input"
            rows="10"
            placeholder="Type Fijian text here… e.g. Bula vinaka"
            class="w-full h-[320px] resize-none rounded-lg border border-border bg-muted/40 px-5 py-4 text-base text-foreground placeholder:text-muted-foreground/60 focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20 transition-all"
            >Era sucu ena galala na tamata yadua, era tautauvata ena nodra dokai kei na nodra dodonu. E tiko na nodra vakasama kei na nodra lewaeloma, sa dodonu mera veidokadokai ena yalo ni veitacini.</textarea
          >
          <p class="mt-2 text-right text-xs text-muted-foreground">
            <span id="char-count">0</span> characters
          </p>
        </div>

        <!-- Output -->
        <div class="flex flex-col p-7">
          <label
            class="mb-2 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-muted-foreground"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-3.5 w-3.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="18" height="18" x="3" y="3" rx="2"></rect><path
                d="M9 9h6"></path><path d="M9 13h4"></path></svg
            >
            English Translation
          </label>
          <div
            id="translation-output"
            class="flex w-full h-[320px] items-start rounded-lg border border-border bg-muted/40 px-5 py-4 text-base text-foreground"
          >
            <span class="text-muted-foreground/60 italic select-none"
              >Translation will appear here…</span
            >
          </div>
        </div>
      </div>

      <!-- Footer / action bar -->
      <div
        class="flex items-center justify-between border-t border-border bg-muted/20 px-7 py-5"
      >
        <p id="error-msg" class="hidden text-xs text-red-500"></p>
        <span class="text-xs text-muted-foreground hidden sm:block"
          >Press <kbd
            class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[11px]"
            >⌘ Enter</kbd
          > to translate</span
        >
        <button
          id="translate-btn"
          class="ml-auto flex items-center gap-2 rounded-lg bg-primary px-7 py-3 text-base font-semibold text-white shadow-md transition-all hover:brightness-110 hover:shadow-primary/30 hover:shadow-lg active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed focus:outline-none focus:ring-2 focus:ring-primary/40"
        >
          <svg
            id="btn-icon"
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="m5 8 6 6"></path><path d="m4 14 6-6 2-3"></path><path
              d="M2 5h12"></path><path d="M7 2h1"></path><path
              d="m22 22-5-10-5 10"></path><path d="M14 18h6"></path>
          </svg>
          <svg
            id="btn-spinner"
            xmlns="http://www.w3.org/2000/svg"
            class="hidden h-4 w-4 animate-spin"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg
          >
          <span id="btn-label">Translate</span>
        </button>
      </div>
    </div>

    <br />
    Use Cases: <b
      >Customer & Client ChatBots, Large Scale Document Translation, Legal
      Research and Drafting, Social Media Marketing.</b
    >
  </div>
</BaseLayout>

<script>
  function updateLogo() {
    const logo = document.getElementById(
      "site-logo",
    ) as HTMLImageElement | null;
    if (!logo) return;
    const isDark =
      document.documentElement.getAttribute("data-theme") === "dark";
    logo.src = isDark
      ? "/agentic-pacific-icon-name-dark.svg"
      : "/agentic-pacific-icon-name-light.svg";
  }

  document.addEventListener("astro:page-load", () => {
    updateLogo();
    const observer = new MutationObserver(updateLogo);
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["data-theme"],
    });
  });
</script>

<script>
  document.addEventListener("astro:page-load", () => {
    const input = document.getElementById(
      "fijian-input",
    ) as HTMLTextAreaElement;
    const output = document.getElementById(
      "translation-output",
    ) as HTMLDivElement;
    const btn = document.getElementById("translate-btn") as HTMLButtonElement;
    const btnLabel = document.getElementById("btn-label") as HTMLSpanElement;
    const btnIcon = document.getElementById("btn-icon") as SVGElement;
    const btnSpinner = document.getElementById("btn-spinner") as SVGElement;
    const charCount = document.getElementById("char-count") as HTMLSpanElement;
    const errorMsg = document.getElementById(
      "error-msg",
    ) as HTMLParagraphElement;
    const statusBadge = document.getElementById(
      "status-badge",
    ) as HTMLSpanElement;

    // Character counter
    input?.addEventListener("input", () => {
      charCount.textContent = String(input.value.length);
    });

    // Cmd/Ctrl+Enter shortcut
    input?.addEventListener("keydown", (e: KeyboardEvent) => {
      if ((e.metaKey || e.ctrlKey) && e.key === "Enter") {
        e.preventDefault();
        doTranslate();
      }
    });

    btn?.addEventListener("click", doTranslate);

    async function doTranslate() {
      const text = input.value.trim();
      if (!text) {
        input.focus();
        return;
      }

      // Loading state
      btn.disabled = true;
      btnLabel.textContent = "Translating…";
      btnIcon.classList.add("hidden");
      btnSpinner.classList.remove("hidden");
      errorMsg.classList.add("hidden");
      output.innerHTML = `<span class="text-muted-foreground/60 italic animate-pulse">Translating…</span>`;

      try {
        const url = `https://sachin1618-ap-fijian.hf.space/translate?fijian_text=${encodeURIComponent(text)}`;
        const res = await fetch(url, {
          method: "POST",
          headers: { accept: "application/json" },
        });

        if (!res.ok) throw new Error(`Server responded with ${res.status}`);

        const data = await res.json();

        // Handle various response shapes
        const translation: string =
          typeof data === "string"
            ? data
            : (data.translation ??
              data.translated_text ??
              data.result ??
              data.output ??
              JSON.stringify(data));

        output.innerHTML = `<span class="text-foreground leading-relaxed">${escapeHtml(translation)}</span>`;
        statusBadge.classList.remove("hidden");
        statusBadge.classList.add("flex");
      } catch (err: unknown) {
        const message = err instanceof Error ? err.message : "Unknown error";
        output.innerHTML = `<span class="text-muted-foreground/60 italic">Translation will appear here…</span>`;
        errorMsg.textContent = `Error: ${message}`;
        errorMsg.classList.remove("hidden");
      } finally {
        btn.disabled = false;
        btnLabel.textContent = "Translate";
        btnIcon.classList.remove("hidden");
        btnSpinner.classList.add("hidden");
      }
    }

    function escapeHtml(str: string): string {
      return str
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;");
    }
  });
</script>
